+"""
+executor.py — Simultaneous Perp-Perp Entry/Exit
+Entry: Both legs fired simultaneously via threads.
+       If either fails, the other is immediately closed.
+Exit:  Both legs closed simultaneously via threads.
+Liquidation: If one leg is liquidated, close the other instantly.
+"""
+import logging
+import time
+import threading
+from typing import Tuple, Dict, Optional
+from src.connectors.base import BaseConnector, SpreadOpportunity
+from src.capital import CapitalManager
+
+logger = logging.getLogger(__name__)
+
+_ENTRY_TIMEOUT  = 15
+_CLOSE_TIMEOUT  = 30  # Increased timeout for reliable closes (API can be slow)
+_PANIC_RETRIES  = 5
+
+
+class PerpExecutor:
+
+    def __init__(self, connectors: Dict[str, BaseConnector], config: dict):
+        self.connectors  = connectors
+        risk             = config.get('risk', {})
+        self.leverage    = float(risk.get('leverage', 1.0))
+        self.capital_pct = float(risk.get('capital_pct', 80.0)) / 100.0
+        self.capital_manager = CapitalManager(
+            leverage=self.leverage,
+            allocate_pct=self.capital_pct,
+        )
+
+    def set_leverage(self, leverage: float):
+        """Update leverage and sync with capital manager."""
+        self.leverage = max(1.0, min(20.0, float(leverage)))
+        self.capital_manager.leverage = self.leverage
+        logger.info(f"[PerpExecutor] Leverage updated to {self.leverage}x")
+
+    def calculate_qty(self, symbol, price, short_exchange, long_exchange, balances):
+        if price <= 0:
+            return 0.0
+        
+        # Ensure capital_manager has latest leverage
+        if self.capital_manager.leverage != self.leverage:
+            self.capital_manager.leverage = self.leverage
+        
+        short_bal = balances.get(short_exchange, 0.0)
+        long_bal  = balances.get(long_exchange, 0.0)
+        qty, _, _ = self.capital_manager.calculate_trade_sizes(
+            short_bal_usdt=short_bal,
+            long_bal_usdt=long_bal,
+            mark_price=price,
+            precision=3,
+        )
+        
+        # Ensure qty meets exchange minimums
+        short_conn = self.connectors.get(short_exchange)
+        long_conn = self.connectors.get(long_exchange)
+        
+        min_qty_short = short_conn.min_order_size if short_conn else 1.0
+        min_qty_long = long_conn.min_order_size if long_conn else 1.0
+        min_qty = max(min_qty_short, min_qty_long)
+        
+        # If calculated qty is below minimum, reduce to max possible respecting minimum
+        if qty > 0 and qty < min_qty:
+            logger.warning(
+                f"[Qty] Calculated qty={qty} below minimum={min_qty} "
+                f"({short_exchange}={min_qty_short}, {long_exchange}={min_qty_long})"
+            )
+            return 0.0  # Signal insufficient balance for this symbol
+        
+        return qty
+
+    def _fire_order(self, result, key, fn, *args, **kwargs):
+        try:
+            res = fn(*args, **kwargs)
+            if isinstance(res, dict) and res.get('success') is False:
+                raise Exception(res.get('error', 'order rejected'))
+            result[key] = {'ok': True, 'data': res}
+        except Exception as e:
+            result[key] = {'ok': False, 'error': str(e)}
+
+    def _panic_close(self, conn, action, symbol, qty):
+        for i in range(_PANIC_RETRIES):
+            try:
+                res = conn.close_short(symbol, qty) if action == 'short' else conn.close_long(symbol, qty)
+                if isinstance(res, dict) and res.get('success') is False:
+                    err = str(res.get('error', '')).lower()
+                    if any(x in err for x in ['no position', 'not found', 'empty', 'zero']):
+                        logger.info(f"[PANIC] {action.upper()} already closed — OK")
+                        return True
+                    raise Exception(res.get('error'))
+                logger.info(f"[PANIC ✓] {action.upper()} {symbol} closed")
+                return True
+            except Exception as e:
+                wait = min(2 ** i, 8)
+                logger.warning(f"[PANIC] {action.upper()} attempt {i+1}/{_PANIC_RETRIES}: {e} — retry in {wait}s")
+                time.sleep(wait)
+        logger.critical(f"[PANIC FAIL] *** {action.upper()} {symbol} COULD NOT BE CLOSED *** CLOSE MANUALLY")
+        return False
+
+    def execute_entry(self, opp, qty):
+        short_conn = self.connectors[opp.short_exchange]
+        long_conn  = self.connectors[opp.long_exchange]
+        symbol     = opp.symbol
+        lev        = int(self.leverage)
+
+        logger.info(
+            f"ENTRY → {symbol} | SHORT:{opp.short_exchange}({opp.short_rate*100:.4f}%) "
+            f"LONG:{opp.long_exchange}({opp.long_rate*100:.4f}%) | Spread:{opp.spread_pct*100:.4f}%"
+        )
+
+        if not short_conn.pre_flight_check(symbol, qty, lev):
+            return False, {"error": f"Pre-flight failed on {opp.short_exchange}"}
+        if not long_conn.pre_flight_check(symbol, qty, lev):
+            return False, {"error": f"Pre-flight failed on {opp.long_exchange}"}
+
+        # Fire BOTH legs simultaneously
+        results = {}
+        t_short = threading.Thread(target=self._fire_order,
+            args=(results, 'short', short_conn.open_short, symbol, qty, lev),
+            daemon=True)
+        t_long  = threading.Thread(target=self._fire_order,
+            args=(results, 'long', long_conn.open_long, symbol, qty, lev),
+            daemon=True)
+
+        t_short.start(); t_long.start()
+        t_short.join(timeout=_ENTRY_TIMEOUT)
+        t_long.join(timeout=_ENTRY_TIMEOUT)
+
+        short_ok  = results.get('short', {}).get('ok', False)
+        long_ok   = results.get('long', {}).get('ok', False)
+        short_err = results.get('short', {}).get('error', 'timeout')
+        long_err  = results.get('long', {}).get('error', 'timeout')
+
+        if short_ok and long_ok:
+            logger.info(f"[ENTRY ✓✓] Both legs filled simultaneously — fully hedged.")
+        elif short_ok and not long_ok:
+            logger.error(f"[ENTRY FAIL] LONG failed: {long_err} — panic closing SHORT immediately")
+            self._panic_close(short_conn, 'short', symbol, qty)
+            return False, {"error": f"LONG failed: {long_err}", "panic_recovery": "attempted"}
+        elif long_ok and not short_ok:
+            logger.error(f"[ENTRY FAIL] SHORT failed: {short_err} — panic closing LONG immediately")
+            self._panic_close(long_conn, 'long', symbol, qty)
+            return False, {"error": f"SHORT failed: {short_err}", "panic_recovery": "attempted"}
+        else:
+            logger.error(f"[ENTRY FAIL] Both legs failed. SHORT:{short_err} LONG:{long_err}")
+            return False, {"error": f"Both failed. SHORT:{short_err} LONG:{long_err}"}
+
+        # Get entry prices
+        time.sleep(0.5)
+        short_entry = long_entry = opp.price
+        try:
+            sp = short_conn.get_position(symbol) or {}
+            lp = long_conn.get_position(symbol) or {}
+            def _ep(d, default):
+                raw = d.get('info', d)
+                for k in ('entryPrice','avg_entry_price','average_price','entry_price','avg_price'):
+                    v = raw.get(k) or d.get(k)
+                    if v: return float(v)
+                return default
+            short_entry = _ep(sp, opp.price)
+            long_entry  = _ep(lp, opp.price)
+        except Exception:
+            pass
+
+        fee_usdt = (short_conn.fee_rate + long_conn.fee_rate) * qty * (opp.price or 1)
+        return True, {
+            "symbol":            symbol,
+            "short_exchange":    opp.short_exchange,
+            "long_exchange":     opp.long_exchange,
+            "qty":               qty,
+            "entry_spread":      opp.spread_pct,
+            "entry_fee_usdt":    fee_usdt,
+            "exit_fee_usdt":     fee_usdt,
+            "break_even_usdt":   fee_usdt * 2,
+            "short_entry_price": short_entry,
+            "long_entry_price":  long_entry,
+        }
+
+    def execute_exit(self, symbol, short_exchange, long_exchange, qty, reason="manual"):
+        short_conn = self.connectors[short_exchange]
+        long_conn  = self.connectors[long_exchange]
+        logger.info(f"EXIT → {symbol} | Qty:{qty} | Reason:{reason}")
+
+        results = {}
+        t_short = threading.Thread(target=self._fire_order,
+            args=(results, 'short', short_conn.close_short, symbol, qty), daemon=True)
+        t_long  = threading.Thread(target=self._fire_order,
+            args=(results, 'long', long_conn.close_long, symbol, qty), daemon=True)
+
+        t_short.start(); t_long.start()
+        t_short.join(timeout=_CLOSE_TIMEOUT)
+        t_long.join(timeout=_CLOSE_TIMEOUT)
+        
+        # Give async operations a bit more time if still running
+        if t_short.is_alive() or t_long.is_alive():
+            import time
+            time.sleep(2)
+            t_short.join(timeout=5)
+            t_long.join(timeout=5)
+
+        short_ok  = results.get('short', {}).get('ok', False)
+        long_ok   = results.get('long', {}).get('ok', False)
+        short_err = results.get('short', {}).get('error', 'timeout')
+        long_err  = results.get('long', {}).get('error', 'timeout')
+
+        # Handle already-closed gracefully
+        for side, err, conn in [('short', short_err, short_conn), ('long', long_err, long_conn)]:
+            if not results.get(side, {}).get('ok'):
+                if any(x in str(err).lower() for x in ['no position','not found','empty','zero']):
+                    logger.info(f"[EXIT] {side.upper()} already closed — OK")
+                    if side == 'short': short_ok = True
+                    else: long_ok = True
+
+        if not short_ok: logger.critical(f"[EXIT FAIL] SHORT {symbol} on {short_exchange} FAILED: {short_err} — CLOSE MANUALLY")
+        if not long_ok:  logger.critical(f"[EXIT FAIL] LONG {symbol} on {long_exchange} FAILED: {long_err} — CLOSE MANUALLY")
+        if short_ok and long_ok: logger.info(f"[EXIT ✓✓] Both legs closed — position fully exited.")
+
+        return (short_ok and long_ok), {
+            "short_closed": short_ok, "long_closed": long_ok,
+            "short_error":  short_err if not short_ok else None,
+            "long_error":   long_err  if not long_ok  else None,
+        }
+
+    def emergency_close_one_leg(self, symbol, exchange, liquidated_side, qty):
+        """Called by liquidation watchdog — closes the OTHER leg immediately."""
+        conn = self.connectors.get(exchange)
+        if not conn:
+            logger.critical(f"[LIQ WATCHDOG] No connector for {exchange} — MANUAL CLOSE NEEDED")
+            return
+        close_side = 'long' if liquidated_side == 'short' else 'short'
+        logger.critical(
+            f"[LIQ WATCHDOG] {liquidated_side.upper()} on {exchange} LIQUIDATED — "
+            f"emergency closing {close_side.upper()} immediately"
+        )
+        self._panic_close(conn, close_side, symbol, qty)
