+"""
+manager.py — Position lifecycle manager.
+Fixes: timezone-aware datetimes throughout, funding dedup by time not amount,
+       correct net PnL including entry/exit prices from DB.
+"""
+import logging
+from datetime import datetime, timezone
+from typing import Dict, List, Tuple, Optional
+import src.auth as auth
+
+logger = logging.getLogger(__name__)
+
+EXIT_REASONS = {
+    'LIQUIDATION_SHORT':         '🔴 Short leg LIQUIDATED',
+    'LIQUIDATION_LONG':          '🔴 Long leg LIQUIDATED',
+    'EMERGENCY_NEGATIVE_SPREAD': '⚠️ Spread went NEGATIVE',
+    'POST_SETTLEMENT_PROFIT':    '✅ Profitable after settlement',
+    'MANUAL_EXIT':               '👤 Manual close',
+}
+
+
+class PerpManager:
+
+    def __init__(self, config: dict, user_id: int):
+        self.exit_floor = config['strategy']['exit_floor_pct'] / 100.0
+        self.user_id    = user_id
+        self.active: Dict[str, dict] = {}
+        self._load()
+
+    def _now(self) -> datetime:
+        return datetime.now(timezone.utc)
+
+    def _save(self):
+        try:
+            for sym, pos in self.active.items():
+                auth.save_user_position(self.user_id, sym, pos)
+        except Exception as e:
+            logger.error(f"[Manager] Save failed user {self.user_id}: {e}")
+
+    def _load(self):
+        try:
+            self.active = auth.get_user_positions(self.user_id)
+            if self.active:
+                logger.info(f"[Manager] Resumed {len(self.active)} position(s) for user {self.user_id}")
+        except Exception as e:
+            logger.error(f"[Manager] Load failed user {self.user_id}: {e}")
+
+    def verify_positions(self, connectors: dict):
+        """Verify all resumed positions still exist on exchanges. Remove stale ones."""
+        to_remove = []
+        for symbol, pos in list(self.active.items()):
+            short_ex = pos.get('short_exchange', '')
+            long_ex = pos.get('long_exchange', '')
+            
+            short_conn = connectors.get(short_ex)
+            long_conn = connectors.get(long_ex)
+            
+            short_exists = False
+            long_exists = False
+            
+            # Check if short leg still exists
+            if short_conn:
+                try:
+                    short_pos = short_conn.get_position(symbol)
+                    short_exists = short_pos is not None and float(short_pos.get('quantity', short_pos.get('qty', 0)) or 0) != 0
+                except Exception as e:
+                    logger.warning(f"[Manager] Could not verify {symbol} short leg on {short_ex}: {e}")
+                    short_exists = True  # Assume exists on error (safer)
+            
+            # Check if long leg still exists
+            if long_conn:
+                try:
+                    long_pos = long_conn.get_position(symbol)
+                    long_exists = long_pos is not None and float(long_pos.get('quantity', long_pos.get('qty', 0)) or 0) != 0
+                except Exception as e:
+                    logger.warning(f"[Manager] Could not verify {symbol} long leg on {long_ex}: {e}")
+                    long_exists = True  # Assume exists on error (safer)
+            
+            # If either leg is closed, remove from active
+            if not short_exists or not long_exists:
+                logger.critical(f"[Manager] STALE POSITION DETECTED: {symbol} - short_exists={short_exists}, long_exists={long_exists}")
+                logger.critical(f"[Manager] Removing {symbol} from active positions (manually closed on exchange)")
+                to_remove.append(symbol)
+        
+        # Remove stale positions
+        for symbol in to_remove:
+            pos = self.active.pop(symbol, None)
+            if pos:
+                auth.remove_user_position(self.user_id, symbol)
+                logger.info(f"[Manager] Removed stale position: {symbol}")
+
+    def add_position(
+        self,
+        symbol: str,
+        short_exchange: str,
+        long_exchange: str,
+        qty: float,
+        entry_spread: float,
+        break_even_usdt: float,
+        entry_fee_usdt: float,
+        short_entry_price: float = 0.0,
+        long_entry_price: float = 0.0,
+    ):
+        now = self._now()
+        self.active[symbol] = {
+            'symbol':               symbol,
+            'short_exchange':       short_exchange,
+            'long_exchange':        long_exchange,
+            'qty':                  qty,
+            'entry_spread':         entry_spread,
+            'break_even_usdt':      break_even_usdt,
+            'entry_fee_usdt':       entry_fee_usdt,
+            'short_entry_price':    short_entry_price,
+            'long_entry_price':     long_entry_price,
+            'cumulative_funding':   0.0,
+            'funding_events':       [],
+            'entry_time':           now,
+            'last_settlement_time': None,
+            'status':               'OPEN',
+            'unrealised_pnl':       0.0,
+            'net_pnl':              -break_even_usdt,
+            '_last_funding_ts':     None,  # timestamp of last funding event (not amount)
+        }
+        self._save()
+        logger.info(f"[Manager] Opened: {symbol} | Break-even: ${break_even_usdt:.4f}")
+
+    def record_funding(self, symbol: str, payout_usdt: float):
+        if symbol not in self.active:
+            return
+        pos = self.active[symbol]
+        now = self._now()
+
+        # Dedup by time (8h window), not by amount — identical payouts are valid
+        last_ts = pos.get('_last_funding_ts')
+        if last_ts is not None:
+            if isinstance(last_ts, str):
+                try:
+                    last_ts = datetime.fromisoformat(last_ts)
+                    if last_ts.tzinfo is None:
+                        last_ts = last_ts.replace(tzinfo=timezone.utc)
+                except Exception:
+                    last_ts = None
+            if last_ts and (now - last_ts).total_seconds() < 3600 * 7:
+                return  # same cycle, skip
+
+        pos['_last_funding_ts']     = now
+        pos['cumulative_funding']   = pos.get('cumulative_funding', 0.0) + payout_usdt
+        pos['last_settlement_time'] = now
+        pos['funding_events'].append({'time': now.isoformat(), 'amount': payout_usdt})
+        self._save()
+        net = pos['cumulative_funding'] - pos['break_even_usdt']
+        logger.info(f"[Funding] {symbol}: +${payout_usdt:.4f} | Cum:${pos['cumulative_funding']:.4f} | Net:${net:+.4f}")
+
+    def remove_position(self, symbol: str, reason: str = '') -> Optional[dict]:
+        pos = self.active.pop(symbol, None)
+        if pos:
+            pos['closed_at']    = self._now().isoformat()
+            pos['close_reason'] = reason
+            auth.update_position_status(self.user_id, symbol, reason)
+            logger.info(f"[Manager] Removed: {symbol} | Reason: {reason}")
+        return pos
+
+    def net_pnl(self, symbol: str, live_short_price: float = None, live_long_price: float = None) -> float:
+        pos = self.active.get(symbol)
+        if not pos:
+            return 0.0
+        realised  = pos.get('cumulative_funding', 0.0) - pos.get('break_even_usdt', 0.0)
+        unrealised = 0.0
+        if live_short_price and live_long_price:
+            se  = pos.get('short_entry_price', 0.0)
+            le  = pos.get('long_entry_price', 0.0)
+            qty = pos.get('qty', 0.0)
+            if se and le and qty:
+                unrealised = (se - live_short_price) * qty + (live_long_price - le) * qty
+        pos['unrealised_pnl'] = unrealised
+        total = realised + unrealised
+        pos['net_pnl'] = total
+        return total
+
+    def check_liquidations(self, connectors: dict) -> List[Tuple[str, str, str]]:
+        events = []
+        for symbol, pos in list(self.active.items()):
+            short_ex = pos['short_exchange']
+            long_ex  = pos['long_exchange']
+            sc = connectors.get(short_ex)
+            lc = connectors.get(long_ex)
+
+            short_exists = True
+            long_exists  = True
+
+            if sc:
+                try:
+                    p = sc.get_position(symbol)
+                    if p is None:
+                        short_exists = False
+                except Exception as e:
+                    logger.warning(f"[LiqCheck] {short_ex} query failed: {e}")
+
+            if lc:
+                try:
+                    p = lc.get_position(symbol)
+                    if p is None:
+                        long_exists = False
+                except Exception as e:
+                    logger.warning(f"[LiqCheck] {long_ex} query failed: {e}")
+
+            # Only flag if API is reachable (i.e. key is configured) to avoid false liquidations on network blips
+            if sc and not short_exists and long_exists:
+                logger.critical(f"[LIQ] {symbol}: SHORT on {short_ex} LIQUIDATED.")
+                events.append((symbol, short_ex, long_ex))
+            elif lc and not long_exists and short_exists:
+                logger.critical(f"[LIQ] {symbol}: LONG on {long_ex} LIQUIDATED.")
+                events.append((symbol, long_ex, short_ex))
+
+        return events
+
+    def monitor(
+        self,
+        current_spreads: Dict[str, float],
+        live_prices: Dict[str, dict] = None,
+        after_settlement: bool = False,
+    ) -> List[Tuple[str, str]]:
+        to_close = []
+        live_prices = live_prices or {}
+
+        for symbol, pos in self.active.items():
+            spread = current_spreads.get(symbol)
+            prices = live_prices.get(symbol, {})
+            self.net_pnl(symbol, prices.get('short'), prices.get('long'))
+
+            if spread is not None and spread < 0:
+                logger.warning(f"[EXIT] {symbol}: Spread NEGATIVE — emergency exit")
+                to_close.append((symbol, 'EMERGENCY_NEGATIVE_SPREAD'))
+                continue
+
+            if after_settlement and pos.get('last_settlement_time') is not None:
+                pnl = pos.get('net_pnl', self.net_pnl(symbol))
+                if pnl > 0:
+                    logger.info(f"[EXIT] {symbol}: Post-settlement profit ${pnl:+.4f} — exiting")
+                    to_close.append((symbol, 'POST_SETTLEMENT_PROFIT'))
+                else:
+                    logger.info(f"[EXIT] {symbol}: Still underwater ${pnl:+.4f} — holding")
+
+        return to_close
