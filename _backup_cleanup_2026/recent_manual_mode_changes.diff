+"""
+src/auth.py — Multi-user authentication and settings persistence.
+
+Stack:
+  - SQLite  (stdlib sqlite3)
+  - bcrypt  (via passlib)
+  - JWT     (via python-jose)
+  - Fernet  (via cryptography — AES API key encryption)
+  - Telegram Bot API (OTP delivery — reuses the same bot as trade notifications)
+
+First registered user → role='admin' automatically.
+Admin: DEMO/LIVE toggle + AUTO mode.
+Regular users: always LIVE, manual entry only.
+OTP required on every login.
+"""
+
+import os
+import random
+import sqlite3
+import logging
+from typing import Optional, Dict
+from datetime import datetime, timedelta, timezone
+import json
+import asyncio
+
+import aiohttp
+from jose import JWTError, jwt
+from cryptography.fernet import Fernet
+import hashlib
+import bcrypt
+
+logger = logging.getLogger(__name__)
+
+# ── OTP store (in-memory, 5-minute TTL) ──────────────────────────────────────
+# key = telegram_chat_id (str) → {code, expires_at, context}
+_otp_store: Dict[str, Dict] = {}
+
+def _generate_otp() -> str:
+    return str(random.randint(100000, 999999))
+
+def _store_otp(chat_id: str, code: str, context: dict):
+    _otp_store[str(chat_id)] = {
+        "code":       code,
+        "expires_at": datetime.now(timezone.utc) + timedelta(minutes=5),
+        "context":    context,
+    }
+
+def verify_otp(chat_id: str, code: str) -> Optional[dict]:
+    """Returns context dict if OTP is valid, else None. Consumes it."""
+    entry = _otp_store.get(str(chat_id))
+    if not entry:
+        return None
+    if entry["expires_at"] < datetime.now(timezone.utc):
+        del _otp_store[str(chat_id)]
+        return None
+    if entry["code"] != str(code).strip():
+        return None
+    del _otp_store[str(chat_id)]
+    return entry["context"]
+
+async def send_otp_via_telegram(chat_id: str, context: dict) -> str:
+    """
+    Generate OTP, store it, and send via the system Telegram bot.
+    Bot token source priority:
+      1. TELEGRAM_BOT_TOKEN env var
+      2. Admin user's telegram_token from Settings Bridge (DB)
+    So users only need to configure it once in the Settings Bridge — no file editing.
+    """
+    code      = _generate_otp()
+    _store_otp(chat_id, code, context)
+    bot_token = os.environ.get("TELEGRAM_BOT_TOKEN", "")
+
+    # Fallback: read from admin user's settings in DB
+    if not bot_token:
+        try:
+            with _conn() as c:
+                row = c.execute(
+                    "SELECT us.telegram_token FROM user_settings us "
+                    "JOIN users u ON u.id = us.user_id "
+                    "WHERE u.role = 'admin' LIMIT 1"
+                ).fetchone()
+                if row:
+                    bot_token = row[0] or ""
+        except Exception:
+            pass
+
+    if not bot_token:
+        logger.warning(f"[Auth] No Telegram bot token configured — OTP for chat_id {chat_id}: {code}")
+        return code  # dev fallback: visible in server logs
+
+    text = (
+        f"🔐 *Alpha Quant Pro — Login OTP*\n\n"
+        f"Your verification code is:\n"
+        f"`{code}`\n\n"
+        f"_Expires in 5 minutes. Do not share._"
+    )
+    url = f"https://api.telegram.org/bot{bot_token}/sendMessage"
+    try:
+        async with aiohttp.ClientSession() as session:
+            async with session.post(url, json={
+                "chat_id":    chat_id,
+                "text":       text,
+                "parse_mode": "Markdown"
+            }) as resp:
+                if resp.status >= 400:
+                    err = await resp.text()
+                    logger.error(f"[Auth] Telegram OTP send failed {resp.status}: {err}")
+                else:
+                    logger.info(f"[Auth] OTP sent via Telegram to chat_id={chat_id}")
+    except Exception as e:
+        logger.error(f"[Auth] Telegram OTP exception: {e}")
+
+    return code
+
+
+# ── Config ────────────────────────────────────────────────────────────────────
+DB_PATH  = os.environ.get("USERS_DB", "users.db")
+JWT_ALGO = "HS256"
+JWT_EXPIRY = 7 * 24 * 60  # minutes — 7 days
+
+# JWT secret: stored in DB so it survives restarts.
+# Tokens remain valid across restarts — users stay logged in.
+
+def _get_jwt_secret() -> str:
+    # Allow override via environment variable
+    env_val = os.environ.get("JWT_SECRET", "")
+    if env_val and env_val != "change-me-in-production-32chars!!":
+        return env_val
+
+    import secrets
+    db = sqlite3.connect(DB_PATH, check_same_thread=False)
+    db.row_factory = sqlite3.Row
+    try:
+        db.execute("""
+            CREATE TABLE IF NOT EXISTS system_config (
+                key   TEXT PRIMARY KEY,
+                value TEXT NOT NULL
+            )
+        """)
+        db.commit()
+        row = db.execute(
+            "SELECT value FROM system_config WHERE key='jwt_secret'"
+        ).fetchone()
+        if row:
+            return row['value']
+        new_secret = secrets.token_hex(32)
+        db.execute(
+            "INSERT INTO system_config (key, value) VALUES ('jwt_secret', ?)",
+            (new_secret,)
+        )
+        db.commit()
+        logger.info("[Auth] Generated and stored JWT secret in database.")
+        return new_secret
+    finally:
+        db.close()
+
+JWT_SECRET = _get_jwt_secret()
+
+# AES key for API key encryption.
+# Stored in the SQLite database so it survives restarts, re-deployments,
+# and file deletions. Generated once on first run, never changes.
+
+def _get_or_create_fernet_key() -> bytes:
+    """
+    Load Fernet key from DB system_config table.
+    Creates the table and generates the key on first run.
+    The key never changes as long as users.db exists.
+    """
+    db = sqlite3.connect(DB_PATH, check_same_thread=False)
+    db.row_factory = sqlite3.Row
+    try:
+        # Ensure system_config table exists
+        db.execute("""
+            CREATE TABLE IF NOT EXISTS system_config (
+                key   TEXT PRIMARY KEY,
+                value TEXT NOT NULL
+            )
+        """)
+        db.commit()
+
+        # Try to load existing key
+        row = db.execute(
+            "SELECT value FROM system_config WHERE key='fernet_key'"
+        ).fetchone()
+
+        if row:
+            stored = row['value']
+            if len(stored) == 43:
+                stored += '='
+            elif len(stored) == 42:
+                stored += '=='
+            key_bytes = stored.encode('utf-8')
+            try:
+                from cryptography.fernet import Fernet as _F
+                _F(key_bytes)
+                return key_bytes
+            except Exception:
+                pass
+
+        # Regenerate if missing or invalid
+
+        # First run — generate and persist
+        new_key = Fernet.generate_key()
+        db.execute(
+            "INSERT INTO system_config (key, value) VALUES ('fernet_key', ?)",
+            (new_key.decode(),)
+        )
+        db.commit()
+        logger.info("[Auth] Generated and stored Fernet key in database.")
+        return new_key
+    finally:
+        db.close()
+
+
+_fernet = None
+def _cipher() -> Fernet:
+    global _fernet
+    if _fernet is None:
+        key = _get_or_create_fernet_key()
+        _fernet = Fernet(key)
+    return _fernet
+
+def _encrypt(value: str) -> str:
+    if not value or value == '********' or value.startswith('****'):
+        return ""
+    return _cipher().encrypt(value.encode()).decode()
+
+def _decrypt(value: str) -> str:
+    if not value:
+        return ""
+    try:
+        return _cipher().decrypt(value.encode()).decode()
+    except Exception as e:
+        logger.warning(f"[Auth] Decryption failed (Key mismatch?): {e}")
+        return ""
+
+# ── API Key & Crypto ────────────────────────────────────────────────────────
+
+def _encode_password(password: str) -> bytes:
+    """Prepares password for bcrypt, staying under the 72-byte limit to prevent passlib wrapper crashes."""
+    pw_bytes = password.encode('utf-8')
+    if len(pw_bytes) > 71:
+        return hashlib.sha256(pw_bytes).digest()
+    return pw_bytes
+
+def _legacy_prehash(password: str) -> bytes:
+    return hashlib.sha256(password.encode('utf-8')).hexdigest().encode('utf-8')
+
+def hash_password(password: str) -> str:
+    salt = bcrypt.gensalt()
+    return bcrypt.hashpw(_encode_password(password), salt).decode('utf-8')
+
+def verify_password(plain_password: str, hashed_password: str) -> bool:
+    try:
+        if bcrypt.checkpw(_encode_password(plain_password), hashed_password.encode('utf-8')):
+            return True
+    except Exception:
+        pass
+    try:
+        if bcrypt.checkpw(_legacy_prehash(plain_password), hashed_password.encode('utf-8')):
+            return True
+    except Exception:
+        pass
+    return False
+
+# ── Database ──────────────────────────────────────────────────────────────────
+def _conn() -> sqlite3.Connection:
+    c = sqlite3.connect(DB_PATH, check_same_thread=False)
+    c.row_factory = sqlite3.Row
+    return c
+
+def init_db():
+    """Create tables if they don't exist. Called once on startup."""
+    with _conn() as c:
+        # system_config must exist before anything else (stores Fernet + JWT keys)
+        c.execute("""
+            CREATE TABLE IF NOT EXISTS system_config (
+                key   TEXT PRIMARY KEY,
+                value TEXT NOT NULL
+            )
+        """)
+        c.executescript("""
+        CREATE TABLE IF NOT EXISTS users (
+            id                 INTEGER PRIMARY KEY AUTOINCREMENT,
+            username           TEXT    UNIQUE NOT NULL,
+            email              TEXT    DEFAULT '',
+            telegram_chat_id   TEXT    DEFAULT '',
+            password_hash      TEXT    NOT NULL,
+            role               TEXT    DEFAULT 'user',
+            created_at         TEXT    DEFAULT (datetime('now'))
+        );
+
+        CREATE TABLE IF NOT EXISTS user_settings (
+            user_id                   INTEGER PRIMARY KEY REFERENCES users(id),
+            min_spread_pct            REAL    DEFAULT 0.05,
+            exit_floor_pct            REAL    DEFAULT 0.02,
+            entry_buffer_minutes      INTEGER DEFAULT 15,
+            stability_scans_required  INTEGER DEFAULT 2,
+            leverage                  INTEGER DEFAULT 5,
+            capital_pct               REAL    DEFAULT 80.0,
+            max_24h_change_pct        REAL    DEFAULT 50.0,
+            max_parallel_arbs         INTEGER DEFAULT 1,
+            rebalance_threshold_pct   REAL    DEFAULT 20.0,
+            delta_key_enc             TEXT    DEFAULT '',
+            delta_secret_enc          TEXT    DEFAULT '',
+            coindcx_key_enc           TEXT    DEFAULT '',
+            coindcx_secret_enc        TEXT    DEFAULT '',
+            coinswitch_key_enc        TEXT    DEFAULT '',
+            coinswitch_secret_enc     TEXT    DEFAULT '',
+            telegram_token            TEXT    DEFAULT '',
+            telegram_chat_id          TEXT    DEFAULT '',
+            baseline_delta            REAL    DEFAULT 0,
+            baseline_coindcx          REAL    DEFAULT 0,
+            baseline_coinswitch       REAL    DEFAULT 0,
+            updated_at                TEXT    DEFAULT (datetime('now'))
+        );
+
+        CREATE TABLE IF NOT EXISTS user_positions (
+            id                    INTEGER PRIMARY KEY AUTOINCREMENT,
+            user_id               INTEGER REFERENCES users(id),
+            symbol                TEXT    NOT NULL,
+            short_exchange        TEXT,
+            long_exchange         TEXT,
+            qty                   REAL,
+            entry_spread          REAL,
+            break_even_usdt       REAL    DEFAULT 0,
+            entry_fee_usdt        REAL    DEFAULT 0,
+            short_entry_price     REAL    DEFAULT 0,
+            long_entry_price      REAL    DEFAULT 0,
+            cumulative_funding    REAL    DEFAULT 0,
+            funding_events_json   TEXT    DEFAULT '[]',
+            entry_time            TEXT,
+            last_settlement_time  TEXT,
+            status                TEXT    DEFAULT 'OPEN'
+        );
+        """)
+        # Migrate: add telegram_chat_id if DB existed without it
+        for col in ("telegram_chat_id", "two_factor_secret"):
+            try:
+                c.execute(f"ALTER TABLE users ADD COLUMN {col} TEXT DEFAULT ''")
+            except Exception:
+                pass  # already exists
+
+        # Migration: Add paper_mode to user_settings
+        try:
+            c.execute("ALTER TABLE user_settings ADD COLUMN paper_mode INTEGER DEFAULT 1")
+        except sqlite3.OperationalError as e:
+            if "duplicate" not in str(e).lower():
+                raise e
+
+        # First registered user becomes admin automatically (see create_user)
+    logger.info(f"[Auth] Database ready at {DB_PATH}")
+
+# ── User management ───────────────────────────────────────────────────────────
+def create_user(username: str, password: str, email: str = "",
+                telegram_chat_id: str = "") -> Dict:
+    """Register a new user. First user becomes admin automatically."""
+    with _conn() as c:
+        count = c.execute("SELECT COUNT(*) FROM users").fetchone()[0]
+        role  = "admin" if count == 0 else "user"
+        cursor = c.execute(
+            "INSERT INTO users (username, email, telegram_chat_id, password_hash, role)"
+            " VALUES (?,?,?,?,?)",
+            (username.strip().lower(), email, telegram_chat_id, hash_password(password), role)
+        )
+        user_id = cursor.lastrowid
+        c.execute("INSERT OR IGNORE INTO user_settings (user_id) VALUES (?)", (user_id,))
+        return {"id": user_id, "username": username.strip().lower(), "role": role}
+
+def get_user(username: str) -> Optional[Dict]:
+    with _conn() as c:
+        row = c.execute(
+            "SELECT id, username, email, telegram_chat_id, password_hash, role, two_factor_secret"
+            " FROM users WHERE username=?",
+            (username.strip().lower(),)
+        ).fetchone()
+        return dict(row) if row else None
+
+def get_user_by_email(email: str) -> Optional[Dict]:
+    with _conn() as c:
+        row = c.execute(
+            "SELECT id, username, email, telegram_chat_id, password_hash, role, two_factor_secret"
+            " FROM users WHERE email=?",
+            (email.strip().lower(),)
+        ).fetchone()
+        return dict(row) if row else None
+
+def authenticate(username_or_email: str, password: str) -> Optional[Dict]:
+    """Validate credentials. Returns user dict if valid, else None."""
+    val = username_or_email.strip().lower()
+    user = get_user(val) or get_user_by_email(val)
+    if not user or not verify_password(password, user["password_hash"]):
+        return None
+    return user
+
+# ── JWT ───────────────────────────────────────────────────────────────────────
+def create_token(user_id: int, role: str) -> str:
+    expire  = datetime.now(timezone.utc) + timedelta(minutes=JWT_EXPIRY)
+    payload = {"sub": str(user_id), "role": role, "exp": expire}
+    return jwt.encode(payload, JWT_SECRET, algorithm=JWT_ALGO)
+
+def decode_token(token: str) -> Dict:
+    """Returns {user_id: int, role: str} or raises ValueError."""
+    try:
+        data = jwt.decode(token, JWT_SECRET, algorithms=[JWT_ALGO])
+        return {"user_id": int(data["sub"]), "role": data["role"]}
+    except JWTError as e:
+        raise ValueError(f"Invalid token: {e}")
+
+# ── Settings ──────────────────────────────────────────────────────────────────
+_PLAIN_FIELDS = {
+    "min_spread_pct", "exit_floor_pct", "entry_buffer_minutes",
+    "stability_scans_required", "leverage", "capital_pct",
+    "max_24h_change_pct", "max_parallel_arbs", "rebalance_threshold_pct",
+    "telegram_token", "telegram_chat_id",
+    "baseline_delta", "baseline_coindcx", "baseline_coinswitch",
+    "paper_mode",
+}
+_ENC_KEY_MAP = {
+    "delta_key":         "delta_key_enc",
+    "delta_secret":      "delta_secret_enc",
+    "coindcx_key":       "coindcx_key_enc",
+    "coindcx_secret":    "coindcx_secret_enc",
+    "coinswitch_key":    "coinswitch_key_enc",
+    "coinswitch_secret": "coinswitch_secret_enc",
+}
+
+def get_settings(user_id: int) -> Dict:
+    with _conn() as c:
+        row = c.execute("SELECT * FROM user_settings WHERE user_id=?", (user_id,)).fetchone()
+        if not row:
+            c.execute("INSERT OR IGNORE INTO user_settings (user_id) VALUES (?)", (user_id,))
+            row = c.execute("SELECT * FROM user_settings WHERE user_id=?", (user_id,)).fetchone()
+        s = dict(row)
+    out = {k: s[k] for k in _PLAIN_FIELDS if k in s}
+    for plain_key, enc_col in _ENC_KEY_MAP.items():
+        out[plain_key] = _decrypt(s.get(enc_col, ""))
+    out["has_delta_key"]      = bool(out.get("delta_key"))
+    out["has_coindcx_key"]    = bool(out.get("coindcx_key"))
+    out["has_coinswitch_key"] = bool(out.get("coinswitch_key"))
+    return out
+
+def save_settings(user_id: int, data: Dict):
+    updates = {}
+    for field in _PLAIN_FIELDS:
+        if field in data and data[field] is not None:
+            updates[field] = data[field]
+    for plain_key, enc_col in _ENC_KEY_MAP.items():
+        if plain_key in data and data[plain_key]:
+            updates[enc_col] = _encrypt(data[plain_key])
+    updates["updated_at"] = datetime.now(timezone.utc).isoformat()
+    if not updates:
+        return
+    cols = ", ".join(f"{k}=?" for k in updates)
+    vals = list(updates.values()) + [user_id]
+    with _conn() as c:
+        c.execute("INSERT OR IGNORE INTO user_settings (user_id) VALUES (?)", (user_id,))
+        c.execute(f"UPDATE user_settings SET {cols} WHERE user_id=?", vals)
+
+def save_baselines(user_id: int, delta: float, coindcx: float, coinswitch: float):
+    save_settings(user_id, {
+        "baseline_delta":    delta,
+        "baseline_coindcx":  coindcx,
+        "baseline_coinswitch": coinswitch,
+    })
+
+def get_user_positions(user_id: int) -> Dict[str, dict]:
+    """Load active positions for a user from DB. Converts times back to datetime objects."""
+    from datetime import datetime
+    with _conn() as c:
+        rows = c.execute(
+            "SELECT * FROM user_positions WHERE user_id=? AND status='OPEN'",
+            (user_id,)
+        ).fetchall()
+        out = {}
+        for r in rows:
+            d = dict(r)
+            sym = d["symbol"]
+            # Parse funding events
+            try:
+                d["funding_events"] = json.loads(d.get("funding_events_json", "[]"))
+            except Exception:
+                d["funding_events"] = []
+            # Convert times back to datetime objects
+            for key in ('entry_time', 'last_settlement_time'):
+                if d.get(key) and isinstance(d[key], str):
+                    try:
+                        # Strip Z or +00:00 for simple fromisoformat if needed, but usually works
+                        d[key] = datetime.fromisoformat(d[key])
+                    except Exception:
+                        pass
+            out[sym] = d
+        return out
+
+def save_user_position(user_id: int, symbol: str, pos: dict):
+    """Insert or Update active position in DB."""
+    with _conn() as c:
+        exists = c.execute(
+            "SELECT id FROM user_positions WHERE user_id=? AND symbol=? AND status='OPEN'",
+            (user_id, symbol)
+        ).fetchone()
+
+        funding_json = json.dumps(pos.get("funding_events", []))
+        entry_time = pos.get("entry_time")
+        if entry_time and hasattr(entry_time, 'isoformat'):
+            entry_time = entry_time.isoformat()
+        last_settlement = pos.get("last_settlement_time")
+        if last_settlement and hasattr(last_settlement, 'isoformat'):
+            last_settlement = last_settlement.isoformat()
+
+        if exists:
+            c.execute(
+                "UPDATE user_positions SET "
+                "short_exchange=?, long_exchange=?, qty=?, entry_spread=?, "
+                "break_even_usdt=?, entry_fee_usdt=?, short_entry_price=?, long_entry_price=?, "
+                "cumulative_funding=?, funding_events_json=?, entry_time=?, last_settlement_time=?, status=? "
+                "WHERE id=?",
+                (
+                    pos.get("short_exchange"), pos.get("long_exchange"), pos.get("qty"), pos.get("entry_spread"),
+                    pos.get("break_even_usdt"), pos.get("entry_fee_usdt"), pos.get("short_entry_price", 0), pos.get("long_entry_price", 0),
+                    pos.get("cumulative_funding", 0), funding_json, entry_time, last_settlement, pos.get("status", "OPEN"),
+                    exists[0]
+                )
+            )
+        else:
+            c.execute(
+                "INSERT INTO user_positions ("
+                "user_id, symbol, short_exchange, long_exchange, qty, entry_spread, "
+                "break_even_usdt, entry_fee_usdt, short_entry_price, long_entry_price, "
+                "cumulative_funding, funding_events_json, entry_time, last_settlement_time, status) "
+                "VALUES (?,?,?,?,?, ?,?,?,?,?, ?,?,?,?,?)",
+                (
+                    user_id, symbol, pos.get("short_exchange"), pos.get("long_exchange"),
+                    pos.get("qty"), pos.get("entry_spread"), pos.get("break_even_usdt"),
+                    pos.get("entry_fee_usdt"), pos.get("short_entry_price", 0), pos.get("long_entry_price", 0),
+                    pos.get("cumulative_funding", 0), funding_json, entry_time, last_settlement, pos.get("status", "OPEN")
+                )
+            )
+
+def update_position_status(user_id: int, symbol: str, status: str):
+    """Mark position status (e.g., CLOSED)."""
+    with _conn() as c:
+        c.execute(
+            "UPDATE user_positions SET status=? WHERE user_id=? AND symbol=? AND status='OPEN'",
+            (status, user_id, symbol)
+        )
+
+def remove_user_position(user_id: int, symbol: str):
+    """Remove a position by marking it CLOSED (for stale/manually closed positions)."""
+    with _conn() as c:
+        c.execute(
+            "UPDATE user_positions SET status='CLOSED' WHERE user_id=? AND symbol=? AND status='OPEN'",
+            (user_id, symbol)
+        )
+
+def get_users_with_active_positions() -> list:
+    with _conn() as c:
+        rows = c.execute("SELECT DISTINCT user_id FROM user_positions WHERE status='OPEN'").fetchall()
+        return [r[0] for r in rows]
+
+def get_all_admins() -> list:
+    with _conn() as c:
+        rows = c.execute("SELECT id FROM users WHERE role='admin'").fetchall()
+        return [r[0] for r in rows]
+
